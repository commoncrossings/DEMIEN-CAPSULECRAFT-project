  --warning: #FF9F0A;
  --success: #32D74B;
  --error: #FF3B30;
  --border: #27272A;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'IBM Plex Mono', monospace;
  background-color: var(--bg-base);
  color: var(--text-primary);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.App {
  min-height: 100vh;
  background-color: var(--bg-base);
}

/* Dashboard Layout */
.dashboard {
  display: grid;
  grid-template-columns: 1fr;
  grid-template-rows: auto 1fr;
  min-height: 100vh;
  gap: 1px;
  background-color: var(--border);
}

@media (min-width: 1024px) {
  .dashboard {
    grid-template-columns: 320px 1fr 380px;
    grid-template-rows: auto 1fr;
  }
}

/* Header */
.dashboard-header {
  grid-column: 1 / -1;
  background-color: var(--bg-surface);
  padding: 12px 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid var(--border);
}

.header-title {
  font-family: 'Chivo', sans-serif;
  font-size: 1.25rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: -0.02em;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: 12px;
}

.header-title svg {
  color: var(--brand-primary);
}

.connection-status {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background-color: var(--error);
}

.status-dot.connected {
  background-color: var(--success);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(50, 215, 75, 0.4); }
  50% { opacity: 0.8; box-shadow: 0 0 0 4px rgba(50, 215, 75, 0); }
}

/* Sidebar Panels */
.sidebar-panel {
  background-color: var(--bg-surface);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.panel-header {
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.panel-title {
  font-family: 'Chivo', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--text-secondary);
}

.panel-badge {
  background-color: rgba(255, 59, 48, 0.2);
  color: var(--brand-primary);
  padding: 2px 8px;
  font-size: 0.625rem;
  font-weight: 600;
  text-transform: uppercase;
  border: 1px solid rgba(255, 59, 48, 0.3);
}

.panel-content {
  flex: 1;
  overflow-y: auto;
  padding: 0;
}

/* Agent Cards */
.agent-list {
  display: flex;
  flex-direction: column;
}

.agent-card {
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  cursor: pointer;
  transition: background-color 0.15s ease;
}

.agent-card:hover {
  background-color: var(--bg-elevated);
}

.agent-card.active {
  background-color: var(--bg-elevated);
  border-left: 2px solid var(--brand-primary);
}

.agent-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.agent-id {
  font-family: 'Chivo', sans-serif;
  font-weight: 700;
  font-size: 0.875rem;
  color: var(--text-primary);
  text-transform: uppercase;
}

.agent-status {
  font-size: 0.625rem;
  padding: 2px 6px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.agent-status.online {
  background-color: rgba(50, 215, 75, 0.2);
  color: var(--success);
  border: 1px solid rgba(50, 215, 75, 0.3);
}

.agent-metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  font-size: 0.6875rem;
}

.metric {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.metric-label {
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.metric-value {
  color: var(--text-primary);
  font-weight: 500;
}

/* Main Map Area */
.map-container {
  background-color: var(--bg-base);
  position: relative;
  overflow: hidden;
}

.map-overlay {
  position: absolute;
  top: 16px;
  left: 16px;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.map-stat {
  background-color: rgba(17, 17, 17, 0.9);
  border: 1px solid var(--border);
  padding: 8px 12px;
  font-size: 0.6875rem;
}

.map-stat-label {
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 2px;
}

.map-stat-value {
  color: var(--text-primary);
  font-size: 1rem;
  font-weight: 600;
}

/* Right Panel - Logs & AI */
.right-panel {
  background-color: var(--bg-surface);
  display: flex;
  flex-direction: column;
}

/* Tabs */
.tabs {
  display: flex;
  border-bottom: 1px solid var(--border);
}

.tab {
  flex: 1;
  padding: 12px 16px;
  font-size: 0.6875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  background: transparent;
  border: none;
  cursor: pointer;
  transition: all 0.15s ease;
  border-bottom: 2px solid transparent;
}

.tab:hover {
  color: var(--text-secondary);
  background-color: var(--bg-elevated);
}

.tab.active {
  color: var(--brand-primary);
  border-bottom-color: var(--brand-primary);
}

/* Log Feed */
.log-feed {
  flex: 1;
  overflow-y: auto;
  font-size: 0.6875rem;
}

.log-entry {
  padding: 8px 16px;
  border-bottom: 1px solid var(--border);
  display: flex;
  gap: 8px;
  align-items: flex-start;
}

.log-time {
  color: var(--text-muted);
  white-space: nowrap;
  min-width: 70px;
}

.log-type {
  padding: 1px 4px;
  font-size: 0.5625rem;
  text-transform: uppercase;
  white-space: nowrap;
}

.log-type.state { background: rgba(33, 150, 243, 0.2); color: #2196F3; }
.log-type.audit { background: rgba(255, 159, 10, 0.2); color: var(--warning); }
.log-type.topology { background: rgba(50, 215, 75, 0.2); color: var(--success); }
.log-type.heartbeat { background: rgba(156, 39, 176, 0.2); color: #9C27B0; }

.log-topic {
  color: var(--text-secondary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* AI Command Interface */
.ai-interface {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.ai-messages {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.ai-message {
  padding: 12px;
  border: 1px solid var(--border);
}

.ai-message.user {
  background-color: var(--bg-elevated);
  border-left: 2px solid var(--brand-primary);
}

.ai-message.assistant {
  background-color: var(--bg-surface);
  border-left: 2px solid var(--success);
}

.ai-message-header {
  font-size: 0.625rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.ai-message-content {
  font-size: 0.8125rem;
  line-height: 1.6;
  color: var(--text-primary);
  white-space: pre-wrap;
}

.ai-input-container {
  padding: 16px;
  border-top: 1px solid var(--border);
  display: flex;
  gap: 8px;
}

.ai-input {
  flex: 1;
  background-color: var(--bg-base);
  border: 1px solid var(--border);
  padding: 12px;
  color: var(--text-primary);
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.8125rem;
  resize: none;
}

.ai-input:focus {
  outline: none;
  border-color: var(--brand-primary);
}

.ai-input::placeholder {
  color: var(--text-muted);
}

.ai-submit {
  background-color: var(--brand-primary);
  color: white;
  border: none;
  padding: 12px 20px;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
  transition: background-color 0.15s ease;
}

.ai-submit:hover {
  background-color: var(--brand-hover);
}

.ai-submit:disabled {
  background-color: var(--brand-secondary);
  cursor: not-allowed;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  color: var(--text-muted);
  text-align: center;
}

.empty-state svg {
  margin-bottom: 16px;
  opacity: 0.5;
}

/* Scrollbar */
::-webkit-scrollbar {
  width: 6px;
}

::-webkit-scrollbar-track {
  background: var(--bg-base);
}

::-webkit-scrollbar-thumb {
  background: var(--border);
}

::-webkit-scrollbar-thumb:hover {
  background: var(--text-muted);
}

/* Canvas for 3D */
.three-canvas {
  width: 100% !important;
  height: 100% !important;
}

/* Loading indicator */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: var(--text-muted);
}

.loading-spinner {
  width: 24px;
  height: 24px;
  border: 2px solid var(--border);
  border-top-color: var(--brand-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
